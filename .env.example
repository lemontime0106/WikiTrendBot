OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# OPENAI_WRITER_MODEL=gpt-5.4-mini
# OPENAI_REVIEW_MODEL=gpt-5.4-mini
# OPENAI_REASONING_EFFORT=medium
# OPENAI_TEMPERATURE=
OPENAI_BASE_URL=https://api.openai.com/v1

CONTENT_SITE_FOCUS=AI 도구 실험, 업무 자동화, 1인 개발·SaaS, AI 산업·정책
CONTENT_MIN_RESEARCH_SOURCES=3
CONTENT_MIN_SOURCE_LINKS=3
CONTENT_MIN_SOURCE_DOMAINS=2
CONTENT_MIN_ARTICLE_CHARS=1800
CONTENT_MIN_EDITORIAL_SCORE=80
CONTENT_DUPLICATE_THRESHOLD=0.72
CONTENT_MAX_REVISION_ROUNDS=1
CONTENT_ALLOW_HIGH_RISK_TOPICS=false

TISTORY_BLOG_URL=https://내블로그.tistory.com
TISTORY_STORAGE_STATE_PATH=.tistory-auth.json
TISTORY_HEADLESS=false
TISTORY_KEEP_BROWSER_OPEN=false
TISTORY_AUTO_FINAL_PUBLISH=false
TISTORY_MANUAL_PUBLISH_TIMEOUT_SECONDS=1800
# TISTORY_LOGIN_ID=
# TISTORY_LOGIN_PASSWORD=
